{
  "name": "flotable",
  "version": "0.1.5",
  "description": "Open-source, ERP-focused table component — zero runtime dependencies",
  "license": "MIT",
  "author": "Fladeed",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fladeed/FTable.git",
    "directory": "packages/flotable"
  },
  "homepage": "https://github.com/Fladeed/FTable#readme",
  "bugs": {
    "url": "https://github.com/Fladeed/FTable/issues"
  },
  "keywords": [
    "react",
    "table",
    "erp",
    "data-table",
    "component",
    "zero-dependency",
    "sorting",
    "filtering",
    "pagination"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles": {
      "types": "./styles.d.ts",
      "default": "./dist/index.css"
    }
  },
  "files": [
    "dist",
    "styles.d.ts"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  }
}
